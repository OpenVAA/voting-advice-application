{
  "private": true,
  "name": "@openvaa/argument-condensation",
  "version": "0.1.0",
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --outDir dist && mkdir -p dist/core/condensation/prompts && find src/core/condensation/prompts -mindepth 1 -maxdepth 1 -type d -exec cp -R {} dist/core/condensation/prompts/ \\;",
    "lint": "eslint --flag v10_config_lookup_from_file src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "dev:vis": "serve tools/visualization"
  },
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "import": "./dist/index.js"
  },
  "devDependencies": {
    "@openvaa/shared-config": "workspace:^",
    "@types/js-yaml": "^4.0.9",
    "dotenv": "^16.3.1",
    "serve": "^14.2.3",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@openvaa/app-shared": "workspace:^",
    "@openvaa/core": "workspace:^",
    "@openvaa/data": "workspace:^",
    "@openvaa/llm": "workspace:^",
    "js-yaml": "^4.1.0"
  }
}
