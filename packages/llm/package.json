{
  "private": true,
  "name": "@openvaa/llm",
  "version": "0.1.0",
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --outDir dist",
    "lint": "eslint --flag v10_config_lookup_from_file src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "import": "./dist/index.js"
  },
  "devDependencies": {
    "@openvaa/shared-config": "workspace:^",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.20",
    "@ai-sdk/openai": "^2.0.31",
    "@openvaa/app-shared": "workspace:^",
    "@openvaa/core": "workspace:^",
    "ai": "^5.0.0",
    "jsonrepair": "^3.13.0",
    "openai": "^4.78.1",
    "zod": "^4.0.0"
  }
}
