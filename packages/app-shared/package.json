{
  "private": true,
  "name": "@openvaa/app-shared",
  "version": "0.1.0",
  "description": "Settings and utilities shared between OpenVAA frontend and backend (Supabase Edge Functions, dev tooling). ESM-only — all current consumers are ESM (`type: module`).",
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --outDir dist",
    "lint": "eslint --flag v10_config_lookup_from_file src/",
    "test:unit": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "@openvaa/data": "workspace:^"
  },
  "devDependencies": {
    "@openvaa/shared-config": "workspace:^",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
