{
  "private": true,
  "name": "@openvaa/question-info",
  "version": "0.1.0",
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --outDir dist && mkdir -p dist/prompts && cp -R src/prompts/* dist/prompts/",
    "lint": "eslint --flag v10_config_lookup_from_file src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "import": "./dist/index.js"
  },
  "devDependencies": {
    "@openvaa/shared-config": "workspace:^",
    "@types/js-yaml": "^4.0.9",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@openvaa/core": "workspace:^",
    "@openvaa/data": "workspace:^",
    "@openvaa/llm": "workspace:^",
    "js-yaml": "^4.1.0",
    "zod": "^4.0.0"
  }
}
