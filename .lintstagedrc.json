{
  "*.{html,js,jsx,cjs,mjssvelte,ts,tsx,cts,mts,xml,yaml,yml}": [
    "bash -c 'turbo run build --filter=@openvaa/app-shared...'",
    "prettier --write",
    "eslint --fix --flag v10_config_lookup_from_file"
  ],
  "*.{css,json,md}": ["bash -c 'turbo run build --filter=@openvaa/app-shared...'", "prettier --write"]
}
