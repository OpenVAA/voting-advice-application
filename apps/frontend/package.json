{
  "name": "@openvaa/frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "svelte-kit sync",
    "dev": "vite dev",
    "build": "svelte-kit sync && vite build && ([ -d \"data\" ] && mkdir -p build/data && cp -r data/ build/ || true)",
    "preview": "vite preview",
    "lint": "eslint --flag v10_config_lookup_from_file src/",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "algorithm-example": "tsx src/matching/examples/example.ts",
    "generate:translation-key-type": "tsx tools/translationKey/generateTranslationKeyType.ts && prettier --write src/lib/types/generated/translationKey.ts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "catalog:",
    "@eslint/js": "catalog:",
    "@openvaa/shared-config": "workspace:^",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "catalog:",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "catalog:",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@vitest/coverage-v8": "^3.2.4",
    "daisyui": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-svelte": "catalog:",
    "globals": "catalog:",
    "jsdom": "^26.1.0",
    "prettier": "catalog:",
    "prettier-plugin-svelte": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "svelte-eslint-parser": "^1.6.0",
    "svelte-visibility-change": "^0.6.0",
    "tailwindcss": "catalog:",
    "tslib": "^2.8.1",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "^6.4.1",
    "vitest": "catalog:"
  },
  "engine": {
    "node": ">=22",
    "yarn": "4.13",
    "npm": "please-use-yarn"
  },
  "type": "module",
  "dependencies": {
    "@inlang/paraglide-js": "^2.15.0",
    "@openvaa/app-shared": "workspace:^",
    "@openvaa/argument-condensation": "workspace:^",
    "@openvaa/core": "workspace:^",
    "@openvaa/data": "workspace:^",
    "@openvaa/filters": "workspace:^",
    "@openvaa/llm": "workspace:^",
    "@openvaa/matching": "workspace:^",
    "@openvaa/question-info": "workspace:^",
    "flat-cache": "^6.1.20",
    "intl-messageformat": "^11.1.3",
    "isomorphic-dompurify": "^3.3.0",
    "jose": "^6.2.1",
    "qs": "^6.15.0",
    "zod": "catalog:"
  },
  "packageManager": "yarn@4.13.0"
}
