{
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "release": "yarn build && changeset publish",
    "changeset": "changeset",
    "watch:shared": "turbo watch build --filter='./packages/*'",
    "dev": "yarn supabase:start && yarn workspace @openvaa/frontend dev",
    "dev:start": "yarn build && yarn supabase:start && yarn workspace @openvaa/frontend dev",
    "dev:down": "yarn supabase:stop",
    "dev:stop": "yarn supabase:stop",
    "dev:reset": "yarn supabase:reset",
    "dev:status": "yarn supabase:status",
    "prepare": "husky",
    "test:e2e": "playwright test -c ./tests/playwright.config.ts ./tests",
    "test:unit": "turbo run test:unit",
    "test:unit:watch": "echo '###################################\nNB! Running only tests in /packages\n###################################\n' && vitest",
    "format": "turbo run build --filter=@openvaa/app-shared... && prettier --write . && yarn workspace @openvaa/docs format",
    "format:check": "turbo run build --filter=@openvaa/app-shared... && prettier --check . && yarn workspace @openvaa/docs format:check",
    "lint:fix": "turbo run lint -- --fix && eslint --flag v10_config_lookup_from_file --fix tests",
    "lint:check": "turbo run lint && eslint --flag v10_config_lookup_from_file tests",
    "docs:prepare": "turbo run build --filter='./packages/*' && yarn workspace @openvaa/frontend prepare",
    "docs:generate": "yarn workspace @openvaa/docs generate",
    "docs:typedoc": "yarn workspace @openvaa/docs generate:typedoc",
    "docs:typedoc-frontend": "yarn workspace @openvaa/docs generate:typedoc-frontend",
    "docs:components": "yarn workspace @openvaa/docs generate:components",
    "docs:routes": "yarn workspace @openvaa/docs generate:routes",
    "docs:dev": "yarn workspace @openvaa/docs dev",
    "supabase:start": "yarn workspace @openvaa/supabase start",
    "supabase:stop": "yarn workspace @openvaa/supabase stop",
    "supabase:reset": "yarn workspace @openvaa/supabase reset",
    "supabase:status": "yarn workspace @openvaa/supabase status",
    "supabase:types": "yarn workspace @openvaa/supabase-types generate",
    "supabase:lint": "yarn workspace @openvaa/supabase lint:all"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@faker-js/faker": "catalog:",
    "@openvaa/shared-config": "workspace:^",
    "@openvaa/supabase-types": "workspace:^",
    "@playwright/test": "catalog:",
    "@supabase/supabase-js": "^2.99.3",
    "@types/cheerio": "^0.22.35",
    "@types/node": "catalog:",
    "cheerio": "^1.0.0",
    "dotenv": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-playwright": "^2.9.0",
    "eslint-plugin-simple-import-sort": "catalog:",
    "glob": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "catalog:",
    "tsup": "^8.5.1",
    "tsx": "catalog:",
    "turbo": "^2.8.17",
    "vitest": "catalog:"
  },
  "engine": {
    "node": ">=22",
    "yarn": "4.13",
    "npm": "please-use-yarn"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "packageManager": "yarn@4.13.0",
  "resolutions": {
    "isomorphic-dompurify/jsdom": "^26.1.0"
  }
}
