################################################################
# Supabase configuration (local dev defaults from `supabase start`)
################################################################

PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

################################################################
# Frontend configuration
################################################################

PUBLIC_BROWSER_FRONTEND_URL=http://localhost:5173
PUBLIC_SERVER_FRONTEND_URL=http://localhost:5173

FRONTEND_PORT=5173

################################################################
# Cache settings
################################################################

PUBLIC_CACHE_ENABLED=false
CACHE_DIR=/var/data/cache
CACHE_TTL=86400000
CACHE_LRU_SIZE=1000
CACHE_EXPIRATION_INTERVAL=3600000

################################################################
# Local data adapter (optional)
################################################################

LOCAL_DATA_DIR=/var/data/local

################################################################
# Identity Provider Configuration
################################################################

# Provider type: 'signicat' or 'idura' (default: signicat)
PUBLIC_IDENTITY_PROVIDER_TYPE=signicat

# --- Shared vars (set to the active provider's values) ---

# OIDC client identifier for the active provider
# Signicat: from https://dashboard.signicat.com/oidc-clients/
# Idura: the application URN (e.g., urn:my:application:identifier:498295)
PUBLIC_IDENTITY_PROVIDER_CLIENT_ID=client_id

# Private decryption JWKS (JSON array) for decrypting JWE id_tokens
# See docs/key-generation.md for generation instructions
IDENTITY_PROVIDER_DECRYPTION_JWKS='[{"kty":"RSA","kid":"{key_id}","use":"enc","alg":"RSA-OAEP","e":"{secret}","n":"{secret}","d":"{secret}","p":"{secret}","q":"{secret}","dp":"{secret}","dq":"{secret}","qi":"{secret}"}]'

# JWKS endpoint for verifying signed id_tokens
# Signicat: from .well-known/openid-configuration
# Idura: https://{domain}/.well-known/openid-configuration/jwks
IDENTITY_PROVIDER_JWKS_URI=https://openvaa.sandbox.signicat.com/auth/open/.well-known/openid-configuration/jwks

# JWT issuer for id_token verification
# Signicat: from .well-known/openid-configuration
# Idura: https://{domain}
IDENTITY_PROVIDER_ISSUER=https://openvaa.sandbox.signicat.com/auth/open

# --- Signicat-specific (only when PUBLIC_IDENTITY_PROVIDER_TYPE=signicat) ---

# Authorization endpoint for client-side PKCE redirect
# Source: https://openvaa.sandbox.signicat.com/auth/open/.well-known/openid-configuration
PUBLIC_IDENTITY_PROVIDER_AUTHORIZATION_ENDPOINT=https://openvaa.sandbox.signicat.com/auth/open/connect/authorize

# Token endpoint for authorization code exchange
IDENTITY_PROVIDER_TOKEN_ENDPOINT=https://openvaa.sandbox.signicat.com/auth/open/connect/token

# Client secret for Signicat token exchange
# Source: https://dashboard.signicat.com/oidc-clients/clientdetails/{client_id}/secrets
IDENTITY_PROVIDER_CLIENT_SECRET=client_secret

# --- Idura-specific (only when PUBLIC_IDENTITY_PROVIDER_TYPE=idura) ---

# Domain for Idura broker (e.g., openvaa.test.idura.broker)
IDURA_DOMAIN=your-subdomain.idura.broker

# Private signing JWKS (JSON array) for JAR + private_key_jwt client authentication
# See docs/key-generation.md for generation instructions
IDURA_SIGNING_JWKS='[{"kty":"RSA","kid":"openvaa-signing-1","use":"sig","alg":"RS256","n":"{secret}","e":"{secret}","d":"{secret}","p":"{secret}","q":"{secret}","dp":"{secret}","dq":"{secret}","qi":"{secret}"}]'

# KID of the signing key to use from IDURA_SIGNING_JWKS
IDURA_SIGNING_KEY_KID=openvaa-signing-1

################################################################
# LLM settings (Admin App)
################################################################

LLM_OPENAI_API_KEY=""

################################################################
# Debugging
################################################################

PUBLIC_DEBUG=false
