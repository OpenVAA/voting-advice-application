## Disclaimer: You most likely don't need this file
## unless you're running the front separately outside of Docker.
## Otherwise please use the .env file in project root.

PUBLIC_BACKEND_URL=http://localhost:1337
PUBLIC_DOCKER_BACKEND_URL=http://strapi:1337 # Used to reach backend instance within the local Docker network

PUBLIC_FRONTEND_URL=http://localhost:5173
PUBLIC_DOCKER_FRONTEND_URL=http://frontend:5173 # Used to reach frontend instance within the local Docker network